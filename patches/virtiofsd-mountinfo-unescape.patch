+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::env;
+    use std::fs::{self, File, OpenOptions};
+    use std::io::Write;
+    use std::process;
+
+    #[test]
+    fn get_mount_root_decodes_mountinfo_octal_escapes() {
+        let path = env::temp_dir().join(format!(
+            "virtiofsd-mountinfo-test-{}",
+            process::id()
+        ));
+        let mut mountinfo = OpenOptions::new()
+            .create(true)
+            .truncate(true)
+            .read(true)
+            .write(true)
+            .open(&path)
+            .unwrap();
+        writeln!(
+            mountinfo,
+            "42 1 8:1 / /mnt/source\\040directory rw,relatime - ext4 /dev/sda rw"
+        )
+        .unwrap();
+
+        let mount_fds = MountFds::new(File::from(mountinfo), None);
+
+        assert_eq!(
+            mount_fds.get_mount_root(42).unwrap(),
+            "/mnt/source directory"
+        );
+        fs::remove_file(path).unwrap();
+    }
+
+    #[test]
+    fn decode_mountinfo_path_preserves_invalid_escapes() {
+        assert_eq!(
+            decode_mountinfo_path("/mnt/foo\\bar/baz"),
+            "/mnt/foo\\bar/baz"
+        );
+    }
+}
