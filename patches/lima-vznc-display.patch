diff --git a/pkg/driver/vz/vz_vnc_darwin.go b/pkg/driver/vz/vz_vnc_darwin.go
new file mode 100644
index 00000000..17833abe
--- /dev/null
+++ b/pkg/driver/vz/vz_vnc_darwin.go
@@ -0,0 +1,134 @@
+//go:build darwin && !no_vz
+
+// SPDX-FileCopyrightText: Copyright The Lima Authors
+// SPDX-License-Identifier: Apache-2.0
+
+// OpenShrimp host-side VNC bridge for the vz driver.
+//
+// When the user sets `video.display: vnc`, instead of opening the
+// limactl graphics window we attach Apple's private _VZVNCServer SPI to
+// the same VZVirtualMachine and bind a TCP listener on 127.0.0.1. The
+// hostagent learns the port via DisplayConnection and writes the
+// standard vncdisplay/vncpasswd files; clients are expected to connect
+// through an RFB filter proxy because Apple's SPI crashes the host
+// process on unfiltered SetEncodings (RFB message type 2) and resets
+// the connection on SetPixelFormat (type 0).
+//
+// Why reflection: Code-Hex/vz keeps the underlying VZVirtualMachine
+// pointer and dispatch_queue_t in unexported fields and the only public
+// pointer accessor is in an `internal/` package. Patching Code-Hex/vz
+// to re-export them would mean maintaining a second downstream patch
+// series for no semantic benefit; reading two unexported pointer fields
+// via reflect on a pinned vz version is the smaller, narrower coupling.
+
+package vz
+
+import (
+	"errors"
+	"fmt"
+	"reflect"
+	"unsafe"
+
+	"github.com/Code-Hex/vz/v3"
+	"github.com/sirupsen/logrus"
+
+	"github.com/lima-vm/lima/v2/pkg/freeport"
+	"github.com/openshrimp/vznc"
+)
+
+// vmRawPointer extracts the raw VZVirtualMachine ObjC pointer that
+// Code-Hex/vz wraps. The struct layout we read against is pinned by
+// `github.com/Code-Hex/vz/v3 v3.7.1` in go.mod; bumping the dep requires
+// re-checking that the embedded `*pointer` field still holds the
+// objc.Pointer (whose first word is the raw `id`).
+func vmRawPointer(vm *vz.VirtualMachine) (unsafe.Pointer, error) {
+	if vm == nil {
+		return nil, errors.New("vznc: nil *vz.VirtualMachine")
+	}
+	val := reflect.ValueOf(vm).Elem()
+	// Embedded `*pointer` (type alias for *internal/objc.Pointer). The
+	// reflect field name of an embedded type is the type name, so
+	// "pointer".
+	field := val.FieldByName("pointer")
+	if !field.IsValid() {
+		return nil, errors.New("vznc: Code-Hex/vz layout changed: no embedded `pointer` field on VirtualMachine")
+	}
+	// field is a *objc.Pointer. Read the pointer value, then the first
+	// word of the pointee, which is `_ptr unsafe.Pointer`.
+	objcPtrAddr := unsafe.Pointer(field.UnsafeAddr())
+	objcPtr := *(*unsafe.Pointer)(objcPtrAddr)
+	if objcPtr == nil {
+		return nil, errors.New("vznc: VirtualMachine.pointer is nil")
+	}
+	raw := *(*unsafe.Pointer)(objcPtr)
+	if raw == nil {
+		return nil, errors.New("vznc: VirtualMachine.pointer._ptr is nil")
+	}
+	return raw, nil
+}
+
+// startVZVNC binds _VZVNCServer to a free localhost TCP port and attaches
+// it to the running VM. Returns the bound port. Caller is responsible for
+// stopping the server in vz Stop().
+func (l *LimaVzDriver) startVZVNC() error {
+	if !vznc.Available() {
+		return errors.New("video.display=vnc: _VZVNCServer SPI not available on this macOS (Virtualization.framework changed?)")
+	}
+	if l.machine == nil || l.machine.VirtualMachine == nil {
+		return errors.New("video.display=vnc: VM not started")
+	}
+	port, err := freeport.TCP()
+	if err != nil {
+		return fmt.Errorf("video.display=vnc: pick free TCP port: %w", err)
+	}
+	if port < 1 || port > 0xFFFF {
+		return fmt.Errorf("video.display=vnc: freeport returned out-of-range port %d", port)
+	}
+
+	// Fresh serial queue for the VNC server. The SPI requires a non-nil
+	// queue (a nil queue causes a delayed SIGSEGV inside
+	// Vnc::Server::ServerDelegate::listener_did_change_state); a queue
+	// distinct from the VM's queue is empirically safe for both Linux
+	// and macOS guests.
+	q := vznc.NewSerialQueue(fmt.Sprintf("openshrimp.vznc.%s", l.Instance.Name))
+
+	sec, err := vznc.NewNoSecurity()
+	if err != nil {
+		q.Close()
+		return fmt.Errorf("video.display=vnc: NoSecurity: %w", err)
+	}
+
+	srv, err := vznc.New(uint16(port), q, sec)
+	if err != nil {
+		sec.Close()
+		q.Close()
+		return fmt.Errorf("video.display=vnc: vznc.New: %w", err)
+	}
+
+	rawVM, err := vmRawPointer(l.machine.VirtualMachine)
+	if err != nil {
+		srv.Close()
+		return fmt.Errorf("video.display=vnc: %w", err)
+	}
+	srv.SetVirtualMachine(rawVM)
+
+	if err := srv.Start(); err != nil {
+		srv.Close()
+		return fmt.Errorf("video.display=vnc: vznc.Start: %w", err)
+	}
+
+	l.vncServer = srv
+	l.vncPort = uint16(port)
+	logrus.Infof("[VZ] _VZVNCServer listening on 127.0.0.1:%d", port)
+	return nil
+}
+
+func (l *LimaVzDriver) stopVZVNC() {
+	if l.vncServer == nil {
+		return
+	}
+	l.vncServer.Stop()
+	l.vncServer.Close()
+	l.vncServer = nil
+	l.vncPort = 0
+}
diff --git a/pkg/driver/vz/vz_vnc_darwin_test.go b/pkg/driver/vz/vz_vnc_darwin_test.go
new file mode 100644
index 00000000..65ec4103
--- /dev/null
+++ b/pkg/driver/vz/vz_vnc_darwin_test.go
@@ -0,0 +1,42 @@
+//go:build darwin && !no_vz
+
+// SPDX-FileCopyrightText: Copyright The Lima Authors
+// SPDX-License-Identifier: Apache-2.0
+
+package vz
+
+import (
+	"reflect"
+	"testing"
+
+	"github.com/Code-Hex/vz/v3"
+)
+
+// TestVZVMReflectedFields pins the unexported field layout of
+// *vz.VirtualMachine that vmRawPointer in vz_vnc_darwin.go relies on. If
+// Code-Hex/vz renames or restructures these fields in a future release,
+// this test fails immediately at build-test time rather than letting the
+// reflection silently misread on a customer machine.
+//
+// Layout reference (Code-Hex/vz v3.7.1, virtualization.go:83-106):
+//
+//	type VirtualMachine struct {
+//	    id            string
+//	    supported     bool
+//	    *pointer      // alias for *internal/objc.Pointer
+//	    dispatchQueue unsafe.Pointer
+//	    ...
+//	}
+func TestVZVMReflectedFields(t *testing.T) {
+	vmType := reflect.TypeOf((*vz.VirtualMachine)(nil)).Elem()
+
+	for _, name := range []string{"pointer", "dispatchQueue"} {
+		f, ok := vmType.FieldByName(name)
+		if !ok {
+			t.Fatalf("Code-Hex/vz layout drift: *vz.VirtualMachine has no %q field; vmRawPointer in vz_vnc_darwin.go will misread", name)
+		}
+		if !f.Anonymous && name == "pointer" {
+			t.Fatalf("expected %q to be embedded (anonymous), got named field", name)
+		}
+	}
+}
