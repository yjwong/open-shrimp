# Minimal container image for running the Claude Code CLI in isolation.
#
# The bundled CLI is a statically-ish linked native binary (only needs
# glibc/libm/libpthread), so a slim Debian base is sufficient — no
# Node.js required.
#
# Build:
#   docker build -f Dockerfile.claude -t openudang-claude:latest \
#     --build-arg CLAUDE_CLI=/path/to/claude .
#
# Or let it auto-detect from an installed claude-agent-sdk:
#   docker build -f Dockerfile.claude -t openudang-claude:latest .

FROM debian:bookworm-slim

# Install common tools the agent might need (git, curl, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create a home directory for the non-root user.
# The actual uid/gid is set at runtime via --user, but the directory
# must exist and be writable.
RUN mkdir -p /home/claude/.claude && chmod 777 /home/claude /home/claude/.claude

# Copy the Claude CLI binary.
# Default: the bundled binary from claude-agent-sdk.
ARG CLAUDE_CLI=.venv/lib/python3.11/site-packages/claude_agent_sdk/_bundled/claude
COPY ${CLAUDE_CLI} /usr/local/bin/claude
RUN chmod +x /usr/local/bin/claude

# Verify it runs.
RUN /usr/local/bin/claude --version || true

ENV HOME=/home/claude
WORKDIR /workspace
